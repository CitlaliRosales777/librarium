<%- include('../partials/header') %>

<div class="breadcrumb">
    <a href="/admin/dashboard">Dashboard</a> / 
    <a href="/admin/usuarios">Usuarios</a> / 
    <%= usuario.Nombre %>
</div>

<div class="libro-main">
    <div class="libro-info">
        <h1><%= usuario.Nombre %> <%= usuario.ApellidoPaterno %> <%= usuario.ApellidoMaterno || '' %></h1>
        
        <div class="libro-meta">
            <span>Correo: <%= usuario.Correo %></span>
            <% if (usuario.Telefono) { %>
                <span>Telefono: <%= usuario.Telefono %></span>
            <% } %>
            <% if (usuario.Ciudad) { %>
                <span> Ciudad: <%= usuario.Ciudad %></span>
            <% } %>
        </div>
        
        <div class="libro-sinopsis">
            <p><strong>Rol:</strong> <%= usuario.NombreRol %></p>
            <p><strong>Registro:</strong> <%= new Date(usuario.FechaRegistro).toLocaleDateString('es-MX') %></p>
            <p>
                <strong>Estado:</strong> 
                <span class="badge <%= usuario.Activo ? 'disponible' : 'no-disponible' %>">
                    <%= usuario.Activo ? 'Activo' : 'Inactivo' %>
                </span>
            </p>
        </div>
        
        <div class="acciones">
            <a href="/admin/usuarios/editar/<%= usuario.IdUsuario %>" class="btn btn-primary">
                Editar
            </a>
        </div>
    </div>
</div>

<!-- Préstamos -->
<div class="seccion">
    <h2>Préstamos (<%= prestamos.length %>)</h2>
    <% if (prestamos.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Libro</th>
                    <th>Código</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                <% prestamos.forEach(function(p) { %>
                <tr>
                    <td><%= p.Titulo %></td>
                    <td><%= p.CodigoBarra %></td>
                    <td><%= new Date(p.FechaPrestamo).toLocaleDateString('es-MX') %></td>
                    <td>
                        <span class="badge <%= p.IdEstadoPrestamo === 1 ? 'no-disponible' : 'disponible' %>">
                            <%= p.IdEstadoPrestamo === 1 ? 'Activo' : 'Devuelto' %>
                        </span>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>Sin préstamos</p>
    <% } %>
</div>

<!-- Multas -->
<% if (multas.length > 0) { %>
<div class="seccion">
    <h2>Multas (<%= multas.length %>)</h2>
    <table>
        <thead>
            <tr>
                <th>Libro</th>
                <th>Monto</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            <% multas.forEach(function(m) { %>
            <tr>
                <td><%= m.Titulo %></td>
                <td>$<%= m.Monto %></td>
                <td>
                    <span class="badge <%= m.Pagado ? 'disponible' : 'no-disponible' %>">
                        <%= m.Pagado ? 'Pagado' : 'Pendiente' %>
                    </span>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
</div>
<% } %>

<%- include('../partials/footer') %>
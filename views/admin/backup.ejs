<%- include('../partials/header') %>

<div class="container mt-4">
    <h1 class="mb-4">Copia de Seguridad</h1>

    <% if (success !== undefined) { %>
        <div class="alert <%= success ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show">
            <%= mensaje %>
            <% if (path) { %>
                <br><small><strong>Ruta:</strong> <code><%= path %></code></small>
            <% } %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-light">
                    <h5>Crear Nuevo Backup</h5>
                </div>
                <div class="card-body text-center py-5">
                    <form action="/admin/backup" method="POST">
                        <button type="submit" class="btn btn-success btn-lg px-5">
                            <i class="fas fa-download me-2"></i>
                            Crear Copia de Seguridad (JSON)
                        </button>
                    </form>
                    
                    <hr class="my-4">
                    
                    <small class="text-muted">
                        Se guardará un archivo JSON con todos los datos principales<br>
                        en la carpeta <code>backups/</code> del proyecto.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
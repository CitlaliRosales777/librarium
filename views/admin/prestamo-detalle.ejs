<%- include('../partials/header') %>

<div class="breadcrumb">
    <a href="/admin/dashboard">Dashboard</a> / 
    <a href="/admin/prestamos">Préstamos</a> / 
    Préstamo #<%= prestamo.IdPrestamo %>
</div>

<div class="libro-main">
    <div class="libro-info">
        <h1><%= prestamo.Titulo %></h1>
        
        <div class="libro-meta">
            <span>ISBN: <%= prestamo.ISBN %></span>
            <span>Código: <%= prestamo.CodigoBarra %></span>
        </div>
        
        <div class="libro-sinopsis">
            <p><strong>Usuario:</strong> <%= prestamo.nombreUsuario %></p>
            <p><strong>Correo:</strong> <%= prestamo.Correo %></p>
            <p><strong>Fecha Préstamo:</strong> <%= new Date(prestamo.FechaPrestamo).toLocaleDateString('es-MX') %></p>
            <p><strong>Fecha Esperada:</strong> <%= new Date(prestamo.FechaDevolucionEsperada).toLocaleDateString('es-MX') %></p>
            
            <% if (prestamo.FechaDevolucionReal) { %>
                <p><strong>Fecha Devolución:</strong> <%= new Date(prestamo.FechaDevolucionReal).toLocaleDateString('es-MX') %></p>
            <% } %>
            
            <% if (prestamo.IdEstadoPrestamo === 1) { %>
                <span class="badge no-disponible">Activo</span>
            <% } else if (prestamo.IdEstadoPrestamo === 2) { %>
                <span class="badge disponible">Devuelto</span>
            <% } %>
            
            <% if (multa) { %>
                <div style="background: #fee; padding: 1rem; margin-top: 1rem; border-radius: 4px;">
                    <strong>Multa:</strong> $<%= multa.Monto %> (por retraso)
                </div>
            <% } %>
        </div>
        
        <div class="acciones">
            <% if (prestamo.IdEstadoPrestamo === 1) { %>
                <form action="/admin/prestamos/devolver/<%= prestamo.IdPrestamo %>" method="POST" style="display: inline;">
                    <button type="submit" class="btn btn-primary">Devolver</button>
                </form>
                
                <form action="/admin/prestamos/renovar/<%= prestamo.IdPrestamo %>" method="POST" style="display: inline;">
                    <input type="hidden" name="dias" value="10">
                    <button type="submit" class="btn btn-secondary">Renovar (10 días)</button>
                </form>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
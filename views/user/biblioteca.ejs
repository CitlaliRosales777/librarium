<%- include('../partials/header') %>
<%- include('../partials/notificaciones') %>

<style>
    .user-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .user-header h1 { color: #0E2B04; margin: 0; }
    .menu-user { display: flex; gap: 0.5rem; }
    .menu-user a {
        padding: 0.75rem 1.25rem;
        background: #364B26;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        transition: all 0.3s;
    }
    .menu-user a:hover { background: #0E2B04; }
    .menu-user a.active { background: #0E2B04; }
    
    .busqueda-container {
        background: white;
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
        margin-bottom: 2rem;
    }
    .busqueda-box {
        display: flex;
        gap: 1rem;
    }
    .busqueda-box input {
        flex: 1;
        padding: 14px 20px;
        border: 2px solid #989D8F;
        border-radius: 8px;
        font-size: 1rem;
    }
    .busqueda-box input:focus {
        outline: none;
        border-color: #0E2B04;
    }
    .busqueda-box button {
        padding: 14px 28px;
        background: #0E2B04;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
    }
    .filtros {
        display: flex;
        gap: 1.5rem;
        margin-top: 1rem;
        flex-wrap: wrap;
    }
    .filtros label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #364B26;
        cursor: pointer;
    }
    .libros-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }
    .libro-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .libro-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(14, 43, 4, 0.2);
    }
    .libro-card-header {
        background: #364B26;
        color: white;
        padding: 1rem 1.25rem;
    }
    .libro-card-header h3 { color: white; margin: 0; font-size: 1.1rem; }
    .libro-card-body { padding: 1.25rem; }
    .libro-info { margin-bottom: 0.75rem; }
    .libro-info span { display: block; font-size: 0.9rem; color: #766F5F; }
    .libro-info strong { color: #0E2B04; }
    .libro-card-footer {
        padding: 1rem 1.25rem;
        background: #C5CDC3;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .badge {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .badge.disponible { background: #27ae60; color: white; }
    .badge.no-disponible { background: #e74c3c; color: white; }
    .no-libros {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 10px;
    }
    .no-libros p { font-size: 1.2rem; color: #766F5F; }
    .contador { margin-bottom: 1.5rem; color: #766F5F; }

    @media (max-width: 768px) {
        .user-header { flex-direction: column; align-items: flex-start; }
        .busqueda-box { flex-direction: column; }
        .libros-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="user-header">
    <h1>Biblioteca</h1>
    <div class="menu-user">
        <a href="/user/biblioteca" class="active">Biblioteca</a>
        <a href="/buscar">Buscar</a>
        <a href="/user/mis-prestamos">Mis Préstamos</a>
        <a href="/user/reservas">Mis Reservas</a>
        <a href="/user/perfil">Mi Perfil</a>
    </div>
</div>

<!-- búsqueda -->
<div class="busqueda-container">
    <div class="busqueda-box">
        <input type="text" id="buscador" placeholder="Buscar por título, autor, ISBN o género...">
        <button onclick="buscar()">Buscar</button>
    </div>
    <div class="filtros">
        <label><input type="radio" name="tipo" value="todo" checked> Todo</label>
        <label><input type="radio" name="tipo" value="libro"> Título</label>
        <label><input type="radio" name="tipo" value="autor"> Autor</label>
        <label><input type="radio" name="tipo" value="isbn"> ISBN</label>
        <label><input type="radio" name="tipo" value="genero"> Género</label>
    </div>
</div>

<p class="contador">Mostrando <%= libros.length %> libros</p>

<!-- resultados búsqueda -->
<div id="resultadosBusqueda" style="display: none;">
    <p class="contador" id="contadorResultados"></p>
    <div class="libros-grid" id="gridResultados"></div>
</div>

<!-- lista de libros -->
<% if (libros && libros.length > 0) { %>
    <div class="libros-grid">
        <% libros.forEach(function(libro) { %>
            <div class="libro-card">
                <div class="libro-card-header">
                    <h3><%= libro.Titulo %></h3>
                </div>
                <div class="libro-card-body">
                    <div class="libro-info">
                        <span><strong>ISBN:</strong> <%= libro.ISBN || 'N/A' %></span>
                        <span><strong>Año:</strong> <%= libro.AnoPublicacion || '-' %></span>
                        <span><strong>Género:</strong> <%= libro.NombreGenero || 'Sin género' %></span>
                        <span><strong>Editorial:</strong> <%= libro.NombreEditorial || 'Sin editorial' %></span>
                    </div>
                    <a href="/user/libro/<%= libro.IdLibro %>" class="btn btn-small">Ver detalles</a>
                </div>
                <div class="libro-card-footer">
                    <% if (libro.disponibles > 0) { %>
                        <span class="badge disponible"><%= libro.disponibles %> disponible(s)</span>
                    <% } else { %>
                        <span class="badge no-disponible">Agotado</span>
                    <% } %>
                </div>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <div class="no-libros">
        <p style="font-size: 3rem;"></p>
        <p>No hay libros en la biblioteca</p>
    </div>
<% } %>

<!-- Script para búsqueda -->
<script>
    var timeoutBusqueda;
    var inputBuscador = document.getElementById('buscador');
    var resultContainer = document.getElementById('resultadosBusqueda');
    var gridResultados = document.getElementById('gridResultados');
    var contadorResultados = document.getElementById('contadorResultados');
    
    inputBuscador.addEventListener('input', function() {
        clearTimeout(timeoutBusqueda);
        timeoutBusqueda = setTimeout(buscar, 300);
    });

    function buscar() {
        var q = inputBuscador.value.trim();
        
        if (q.length < 2) {
            resultContainer.style.display = 'none';
            return;
        }
        
        var tipo = document.querySelector('input[name="tipo"]:checked').value;
        
        // ✅ CAMBIO CLAVE: usar /api/buscar en lugar de /user/buscar
        fetch('/api/buscar?q=' + encodeURIComponent(q) + '&tipo=' + tipo)
            .then(function(r) { return r.json(); })
            .then(mostrarResultados)
            .catch(function(err) { 
                console.error('Error:', err); 
                gridResultados.innerHTML = '<p style="color: red;">Error en la búsqueda</p>';
            });
    }

    function mostrarResultados(libros) {
        gridResultados.innerHTML = '';
        
        if (!libros || libros.length === 0) {
            resultContainer.style.display = 'block';
            gridResultados.innerHTML = '<p style="grid-column: 1/-1; text-align: center; color: #766F5F;">No se encontraron resultados</p>';
            return;
        }
        
        contadorResultados.textContent = 'Se encontraron ' + libros.length + ' resultados';
        
        libros.forEach(function(libro) {
            var card = document.createElement('div');
            card.className = 'libro-card';
            card.innerHTML = 
                '<div class="libro-card-header">' +
                    '<h3>' + libro.Titulo + '</h3>' +
                '</div>' +
                '<div class="libro-card-body">' +
                    '<div class="libro-info">' +
                        '<span><strong>ISBN:</strong> ' + (libro.ISBN || 'N/A') + '</span>' +
                        '<span><strong>Año:</strong> ' + (libro.AnoPublicacion || '-') + '</span>' +
                        '<span><strong>Género:</strong> ' + (libro.NombreGenero || '-') + '</span>' +
                        '<span><strong>Editorial:</strong> ' + (libro.NombreEditorial || '-') + '</span>' +
                    '</div>' +
                    '<a href="/user/libro/' + libro.IdLibro + '" class="btn btn-small">Ver detalles</a>' +
                '</div>' +
                '<div class="libro-card-footer">' +
                    (libro.disponibles > 0 ? 
                        '<span class="badge disponible">' + libro.disponibles + ' disponible(s)</span>' :
                        '<span class="badge no-disponible">Agotado</span>') +
                '</div>';
            gridResultados.appendChild(card);
        });
        
        resultContainer.style.display = 'block';
    }
</script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

<style>
    .perfil-container {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 2rem;
    }
    
    .perfil-sidebar {
        background: white;
        border-radius: 10px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
    }
    .perfil-avatar {
        width: 120px;
        height: 120px;
        background: #364B26;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 3rem;
        color: white;
    }
    .perfil-nombre {
        font-size: 1.5rem;
        color: #0E2B04;
        margin-bottom: 0.25rem;
    }
    .perfil-correo {
        color: #766F5F;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }
    .perfil-badge {
        display: inline-block;
        padding: 0.4rem 1rem;
        background: #27ae60;
        color: white;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    
    .perfil-main {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }
    .stat-card {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
    }
    .stat-card .numero {
        font-size: 2.5rem;
        font-weight: bold;
        color: #0E2B04;
    }
    .stat-card .label {
        color: #766F5F;
        font-size: 0.9rem;
    }
    .stat-card.prestamos .numero { color: #e67e22; }
    .stat-card.reservas .numero { color: #3498db; }
    .stat-card.multas .numero { color: #e74c3c; }
    
    .seccion {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
    }
    .seccion h2 {
        color: #0E2B04;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #C5CDC3;
    }
    
    .datos-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    .dato-item label {
        display: block;
        font-size: 0.8rem;
        color: #766F5F;
        text-transform: uppercase;
    }
    .dato-item span {
        color: #0E2B04;
        font-weight: 500;
    }
    
    .lista-libros {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .libro-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
    }
    .libro-item .info h4 {
        margin: 0;
        color: #0E2B04;
    }
    .libro-item .info p {
        margin: 0.25rem 0 0;
        color: #766F5F;
        font-size: 0.85rem;
    }
    .badge {
        padding: 0.3rem 0.75rem;
        border-radius: 15px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .badge.activo { background: #e67e22; color: white; }
    .badge.devuelto { background: #27ae60; color: white; }
    .badge.reserva { background: #3498db; color: white; }
    .badge.vencido { background: #e74c3c; color: white; }
    
    .empty {
        text-align: center;
        padding: 2rem;
        color: #766F5F;
    }
    
    .menu-user {
        display: flex;
        gap: 0.5rem;
    }
    .menu-user a {
        padding: 0.75rem 1.25rem;
        background: #364B26;
        color: white;
        text-decoration: none;
        border-radius: 6px;
    }
    .menu-user a:hover { background: #0E2B04; }
    .menu-user a.active { background: #0E2B04; }

    @media (max-width: 768px) {
        .perfil-container { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: 1fr; }
        .datos-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="user-header" style="margin-bottom: 1.5rem;">
    <h1>👤 Mi Perfil</h1>
    <div class="menu-user">
        <a href="/user/biblioteca">Biblioteca</a>
        <a href="/user/reservas">Mis Reservas</a>
    </div>
</div>

<div class="perfil-container">
    <!-- Sidebar con datos del usuario -->
    <div class="perfil-sidebar">
        <div class="perfil-avatar">
            <%= usuario.Nombre.charAt(0).toUpperCase() %>
        </div>
        <h2 class="perfil-nombre"><%= usuario.Nombre %> <%= usuario.ApellidoPaterno %></h2>
        <p class="perfil-correo"><%= usuario.Correo %></p>
        <span class="perfil-badge"><%= usuario.NombreRol %></span>
    </div>
    
    <!-- Contenido principal -->
    <div class="perfil-main">
        
        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card prestamos">
                <div class="numero"><%= prestamosActivos.length %></div>
                <div class="label">Préstamos Activos</div>
            </div>
            <div class="stat-card reservas">
                <div class="numero"><%= misReservas.length %></div>
                <div class="label">Reservas</div>
            </div>
            <div class="stat-card multas">
                <div class="numero"><%= multasPendientes.length %></div>
                <div class="label">Multas Pendientes</div>
            </div>
        </div>
        
        <!-- Mis datos -->
        <div class="seccion">
            <h2>📝 Mis Datos</h2>
            <div class="datos-grid">
                <div class="dato-item">
                    <label>Nombre completo</label>
                    <span><%= usuario.Nombre %> <%= usuario.ApellidoPaterno %> <%= usuario.ApellidoMaterno || '' %></span>
                </div>
                <div class="dato-item">
                    <label>Teléfono</label>
                    <span><%= usuario.Telefono || 'No registrado' %></span>
                </div>
                <div class="dato-item">
                    <label>Ciudad</label>
                    <span><%= usuario.Ciudad || 'No registrada' %></span>
                </div>
                <div class="dato-item">
                    <label>Fecha de registro</label>
                    <span><%= new Date(usuario.FechaRegistro).toLocaleDateString('es-MX') %></span>
                </div>
            </div>
        </div>
        
        <!-- Préstamos activos -->
        <div class="seccion">
            <h2>📖 Mis Préstamos Activos</h2>
            <% if (prestamosActivos.length > 0) { %>
                <div class="lista-libros">
                    <% prestamosActivos.forEach(function(p) { %>
                        <div class="libro-item">
                            <div class="info">
                                <h4><%= p.Titulo %></h4>
                                <p>Fecha límite: <%= new Date(p.FechaDevolucionEsperada).toLocaleDateString('es-MX') %></p>
                            </div>
                            <span class="badge activo">Activo</span>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty">No tienes préstamos activos</div>
            <% } %>
        </div>
        
        <!-- Reservas -->
        <div class="seccion">
            <h2>🔔 Mis Reservas</h2>
            <% if (misReservas.length > 0) { %>
                <div class="lista-libros">
                    <% misReservas.forEach(function(r) { %>
                        <div class="libro-item">
                            <div class="info">
                                <h4><%= r.Titulo %></h4>
                                <p>Expira: <%= new Date(r.FechaExpiracion).toLocaleDateString('es-MX') %></p>
                            </div>
                            <span class="badge reserva">Reservado</span>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty">No tienes reservas</div>
            <% } %>
        </div>
        
    </div>
</div>

<%- include('../partials/footer') %>
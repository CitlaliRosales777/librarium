<%- include('../partials/header') %>
<%- include('../partials/notificaciones') %>

<style>
    .confirm-container {
        max-width: 520px;
        margin: 2rem auto;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(14, 43, 4, 0.12);
        overflow: hidden;
    }
    .confirm-header {
        background: linear-gradient(135deg, #e67e22, #f39c12);
        color: white;
        padding: 2.2rem 1.5rem;
        text-align: center;
    }
    .confirm-header .icono {
        font-size: 4.5rem;
        margin-bottom: 0.8rem;
    }
    .confirm-header h1 {
        margin: 0;
        font-size: 1.8rem;
    }
    .confirm-body {
        padding: 2rem;
    }
    .libro-info {
        background: #f8f9fa;
        padding: 1.6rem;
        border-radius: 10px;
        margin-bottom: 1.8rem;
        border-left: 5px solid #e67e22;
    }
    .libro-info h2 {
        color: #0E2B04;
        margin-bottom: 1.2rem;
        font-size: 1.4rem;
    }
    .detalle {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.7rem;
        font-size: 1rem;
    }
    .detalle span:first-child {
        color: #766F5F;
    }
    .detalle span:last-child {
        color: #0E2B04;
        font-weight: 600;
    }
    .info-reserva {
        background: #C5CDC3;
        padding: 1.4rem;
        border-radius: 10px;
        margin-bottom: 2rem;
    }
    .info-reserva p {
        margin: 0.6rem 0;
        color: #0E2B04;
    }
    .aviso {
        background: #fff3cd;
        border: 1px solid #ffc107;
        padding: 1.1rem;
        border-radius: 8px;
        margin-bottom: 1.8rem;
    }
    .aviso p {
        margin: 0;
        color: #856404;
        font-size: 0.95rem;
    }
    .confirm-actions {
        display: flex;
        gap: 1rem;
    }
    .btn-confirmar {
        flex: 1;
        padding: 1.1rem;
        background: #27ae60;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-confirmar:hover { 
        background: #1e8449;
        transform: translateY(-2px);
    }
    .btn-cancelar {
        flex: 1;
        padding: 1.1rem;
        background: #e74c3c;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s;
    }
    .btn-cancelar:hover { 
        background: #c0392b;
        transform: translateY(-2px);
    }
</style>

<div class="confirm-container">
    <div class="confirm-header">
        <div class="icono"></div>
        <h1>Confirmar Reserva</h1>
    </div>
    
    <div class="confirm-body">
        <div class="aviso">
            <p><strong>Importante:</strong> Esta reserva estará vigente por <strong>3 días</strong>. 
            Si no retiras el libro en ese tiempo, la reserva caducará automáticamente.</p>
        </div>
        
        <div class="libro-info">
            <h2><%= libro.Titulo %></h2>
            <div class="detalle">
                <span>ISBN:</span>
                <span><%= libro.ISBN || 'N/A' %></span>
            </div>
            <div class="detalle">
                <span>Género:</span>
                <span><%= libro.NombreGenero || 'Sin género' %></span>
            </div>
            <div class="detalle">
                <span>Editorial:</span>
                <span><%= libro.NombreEditorial || 'Sin editorial' %></span>
            </div>
            <div class="detalle">
                <span>Año:</span>
                <span><%= libro.AnoPublicacion || 'N/A' %></span>
            </div>
        </div>
        
        <div class="info-reserva">
            <p><strong>Fecha de reserva:</strong> <%= new Date().toLocaleDateString('es-MX') %></p>
            <p><strong>Expira el:</strong> <%= fechaExpiracion %></p>
            <p><strong>Código del ejemplar:</strong> <strong><%= codigoBarra %></strong></p>
        </div>
        
        <form action="/user/reservar" method="POST">
            <input type="hidden" name="IdEjemplar" value="<%= idEjemplar %>">
            <input type="hidden" name="confirmar" value="1">
            
            <div class="confirm-actions">
                <a href="/user/libro/<%= libro.IdLibro %>" class="btn-cancelar">
                    Cancelar
                </a>
                <button type="submit" class="btn-confirmar">
                    Confirmar Reserva
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
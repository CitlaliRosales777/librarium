<%- include('../partials/header') %>

<style>
    .confirm-container {
        max-width: 500px;
        margin: 2rem auto;
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 10px rgba(14, 43, 4, 0.1);
    }
    .confirm-header {
        background: #27ae60;
        color: white;
        padding: 2rem;
        text-align: center;
    }
    .confirm-header h1 { color: white; margin: 0; }
    .confirm-body { padding: 2rem; }
    .libro-box {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }
    .libro-box h2 { color: #0E2B04; margin-bottom: 1rem; }
    .libro-box p { margin: 0.5rem 0; color: #766F5F; }
    .libro-box strong { color: #0E2B04; }
    .btn-confirm { width: 100%; padding: 1rem; background: #27ae60; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 1rem; }
    .btn-confirm:hover { background: #1e8449; }
    .btn-cancel { display: block; text-align: center; margin-top: 1rem; color: #766F5F; }
</style>

<div class="confirm-container">
    <div class="confirm-header">
        <h1>📖 Confirmar Préstamo</h1>
    </div>
    <div class="confirm-body">
        <div class="libro-box">
            <h2><%= titulo %></h2>
            <p><strong>Código:</strong> <%= codigoBarra %></p>
            <p><strong>Fecha límite:</strong> <%= fechaLimite %></p>
        </div>
        <form action="/user/prestamo/inmediato" method="POST">
            <input type="hidden" name="IdReserva" value="<%= idReserva %>">
            <input type="hidden" name="IdEjemplar" value="<%= idEjemplar %>">
            <button type="submit" class="btn-confirm">✓ Confirmar Préstamo</button>
        </form>
        <a href="/user/reservas" class="btn-cancel">← Mis Reservas</a>
    </div>
</div>

<%- include('../partials/footer') %>